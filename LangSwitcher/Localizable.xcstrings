      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "엔터 키를 누를 때도 오타 교정을 시도합니다. (터미널에서 'cle', 'cd' 같은 짧은 명령어를 입력할 때 원치 않는 변환이 발생할 수 있습니다.)"
          }
        }
      }

    "Are you sure you want to delete all recorded statistics? This action cannot be undone." : {
      "comment" : "Confirmation dialog message for resetting all statistics.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기록된 모든 통계 데이터를 삭제하시겠습니까? 이 작업은 실행 후 되돌릴 수 없습니다."
          }
        }
      }
    },
    "Assign a shortcut to quickly open or switch to a specific application." : {
      "comment" : "A description of the app launch shortcuts feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "단축키를 할당하여 특정 앱을 빠르게 실행하거나 전환합니다."
          }
        }
      }

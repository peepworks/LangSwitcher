    },
    "Automatically check for updates" : {
      "comment" : "Toggle to enable or disable automatic checking for software updates.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "자동으로 업데이트 확인"
          }
        }
      }
    },
    "Automatically clears stored window language data when the application is closed to optimize memory." : {
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메모리 최적화를 위해 앱이 완전히 종료되면 해당 앱의 윈도우별 언어 기록을 초기화합니다."
          }
        }
      }
    },
    "Automatically detects when you type Korean words in English layout (e.g., 'dkssud' → '안녕') and converts them instantly upon pressing Space." : {
      "comment" : "Description of the smart auto-correction feature that automatically corrects typos when Korean words are typed in English layout.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "영문 자판 상태에서 한글을 입력할 때(예: 'dkssud' → '안녕') 이를 자동으로 감지하여 스페이스바를 누르는 즉시 한글로 변환합니다."
          }
        }
      }
    },
    "Automatically switch to a specific language when an app becomes active." : {
      "comment" : "A description of the feature that automatically switches to a specific language when an app becomes active.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",

      }
    },
    "Automatically clears stored window language data when the application is closed to optimize memory." : {
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메모리 최적화를 위해 앱이 완전히 종료되면 해당 앱의 윈도우별 언어 기록을 초기화합니다."
          }
        }
      }
    },
    "Automatically fixes English/Korean typing errors (e.g., dkssud → 안녕) using a global shortcut." : {
      "comment" : "A description of the auto-typo correction feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "전역 단축키를 사용하여 영어/한국어 입력 오류(예: dkssud → 안녕)를 자동으로 수정합니다."
          }
        }
      }
    },
    "Automatically switch to a specific language when an app becomes active." : {
      "comment" : "A description of the feature that automatically switches to a specific language when an app becomes active.",
